// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  employee
}

enum StockMovementType {
  purchase
  sale
  service_use
  adjustment
}

enum InvoiceStatus {
  draft
  issued
  paid
  cancelled
}

enum ServiceJobStatus {
  pending
  in_progress
  completed
  delivered
  cancelled
}

model User {
  id           String      @id @default(uuid()) @db.Char(36)
  name         String
  username     String      @unique
  passwordHash String
  role         Role        @default(employee)
  purchases    Purchase[]
  stockLogs    StockLog[]
  invoices     Invoice[]
  serviceJobs  ServiceJob[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Customer {
  id           String       @id @default(uuid()) @db.Char(36)
  name         String
  phone        String?      @unique
  email        String?      @unique
  invoices     Invoice[]
  serviceJobs  ServiceJob[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Brand {
  id          String       @id @default(uuid()) @db.Char(36)
  name        String       @unique
  products    Product[]
  serviceJobs ServiceJob[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Product {
  id           String        @id @default(uuid()) @db.Char(36)
  name         String
  sku          String?       @unique
  description  String?       @db.Text
  unitPrice    Decimal       @db.Decimal(10, 2)
  gstRate      Decimal       @default(0) @db.Decimal(5, 2)
  costPrice    Decimal?      @db.Decimal(10, 2)
  stock        Int           @default(0)
  brandId      String?       @db.Char(36)
  brand        Brand?        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  purchases    Purchase[]
  stockLogs    StockLog[]
  invoiceItems InvoiceItem[]
  serviceItems ServiceItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Purchase {
  id            String      @id @default(uuid()) @db.Char(36)
  purchaseCode  String      @unique
  productId     String      @db.Char(36)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity      Int
  unitCost      Decimal     @db.Decimal(10, 2)
  totalCost     Decimal     @db.Decimal(12, 2)
  supplierName  String?
  notes         String?     @db.Text
  purchasedById String      @db.Char(36)
  purchasedBy   User        @relation(fields: [purchasedById], references: [id], onDelete: Restrict)
  stockLogs     StockLog[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model StockLog {
  id            String            @id @default(uuid()) @db.Char(36)
  productId     String            @db.Char(36)
  product       Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  changedById   String?           @db.Char(36)
  changedBy     User?             @relation(fields: [changedById], references: [id], onDelete: SetNull)
  movementType  StockMovementType
  quantity      Int
  balanceAfter  Int
  note          String?           @db.Text
  purchaseId    String?           @db.Char(36)
  purchase      Purchase?         @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  invoiceItemId String?           @db.Char(36)
  invoiceItem   InvoiceItem?      @relation(fields: [invoiceItemId], references: [id], onDelete: SetNull)
  serviceItemId String?           @db.Char(36)
  serviceItem   ServiceItem?      @relation(fields: [serviceItemId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Invoice {
  id            String         @id @default(uuid()) @db.Char(36)
  invoiceNumber String         @unique
  customerId    String?        @db.Char(36)
  customer      Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName  String
  customerPhone String?
  customerEmail String?
  subtotal      Decimal        @db.Decimal(12, 2)
  gstRate       Decimal        @default(0) @db.Decimal(5, 2)
  gstAmount     Decimal        @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal        @default(0) @db.Decimal(12, 2)
  totalCost     Decimal        @default(0) @db.Decimal(12, 2)
  profitAmount  Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal        @db.Decimal(12, 2)
  status        InvoiceStatus  @default(draft)
  billedById    String         @db.Char(36)
  billedBy      User           @relation(fields: [billedById], references: [id], onDelete: Restrict)
  items         InvoiceItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model InvoiceItem {
  id          String      @id @default(uuid()) @db.Char(36)
  invoiceId   String      @db.Char(36)
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?     @db.Char(36)
  product     Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  description String
  quantity    Int
  unitCost    Decimal     @default(0) @db.Decimal(10, 2)
  unitPrice   Decimal     @db.Decimal(10, 2)
  gstRate     Decimal     @default(0) @db.Decimal(5, 2)
  gstAmount   Decimal     @default(0) @db.Decimal(12, 2)
  profit      Decimal     @default(0) @db.Decimal(12, 2)
  total       Decimal     @db.Decimal(12, 2)
  stockLogs   StockLog[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model ServiceJob {
  id            String           @id @default(uuid()) @db.Char(36)
  jobNumber     String           @unique
  customerId    String?          @db.Char(36)
  customer      Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName  String
  customerPhone String?
  deviceName    String
  deviceModel   String?
  serialNumber  String?
  complaint     String?          @db.Text
  diagnosis     String?          @db.Text
  serviceCharge Decimal          @default(0) @db.Decimal(10, 2)
  partsCost     Decimal          @default(0) @db.Decimal(12, 2)
  profitAmount  Decimal          @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal          @default(0) @db.Decimal(12, 2)
  status        ServiceJobStatus @default(pending)
  brandId       String?          @db.Char(36)
  brand         Brand?           @relation(fields: [brandId], references: [id], onDelete: SetNull)
  assignedToId  String?          @db.Char(36)
  assignedTo    User?            @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  items         ServiceItem[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model ServiceItem {
  id           String      @id @default(uuid()) @db.Char(36)
  serviceJobId String      @db.Char(36)
  serviceJob   ServiceJob  @relation(fields: [serviceJobId], references: [id], onDelete: Cascade)
  productId    String?     @db.Char(36)
  product      Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  description  String
  quantity     Int
  unitCost     Decimal     @default(0) @db.Decimal(10, 2)
  unitPrice    Decimal     @db.Decimal(10, 2)
  profit       Decimal     @default(0) @db.Decimal(12, 2)
  total        Decimal     @db.Decimal(12, 2)
  stockLogs    StockLog[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}
